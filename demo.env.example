# Replace YOUR_DOCKERHUB_ID with the Docker Hub account ID.
APP_IMAGE=YOUR_DOCKERHUB_ID/onmom-backend:demo

MYSQL_DATABASE=onmom
MYSQL_USER=onmom_user
# Generate these with: openssl rand -hex 32
MYSQL_PASSWORD=replace-with-a-random-password
MYSQL_ROOT_PASSWORD=replace-with-a-different-random-password

# Generate with: openssl rand -hex 32
ONMOM_JWT_SECRET=replace-with-a-random-jwt-secret
# This is intentionally true only for a short demo: it enables /api/v1/dev/auth endpoints.
ONMOM_DEV_TOKEN_ENABLED=true
# Local React/Vite development servers allowed to call this demo API.
ONMOM_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
