        {
          "name": "List Chat Session Messages",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('chat messages listed', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  if (json.data.page && json.data.page.nextCursor) {",
                  "    pm.environment.set('chatCursor', json.data.page.nextCursor);",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
