{
  "info": {
    "_postman_id": "149a2d90-cbb7-41d3-9ed5-1d4377b6c5b3",
    "name": "Onmom Local API",
    "description": "Local Postman collection for the currently implemented Onmom backend APIs. Import docs/postman/onmom-local.postman_environment.json and select the Onmom Local environment before running requests.",
