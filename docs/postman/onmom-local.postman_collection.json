              ],
              "path": [
                "api",
                "v1",
                "chat-sessions",
                "{{chatSessionId}}",
                "messages"
              ],
              "query": [
                {
                  "key": "size",
                  "value": "20"
                }
              ]
            }
          },
          "response": []
        }
      ]
