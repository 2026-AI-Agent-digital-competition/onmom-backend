    {
      "name": "05 Family Insight And Messages",
      "item": [
        {
          "name": "Create Family Insight",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('family insight created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.environment.set('translationId', String(json.data.translationId));",
                  "  if (json.data.familyMessageIds && json.data.familyMessageIds.length > 0) {",
                  "    pm.environment.set('familyMessageId', String(json.data.familyMessageIds[0]));",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{motherToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pregnancyId\": {{pregnancyId}},\n  \"recipientUserId\": {{familyUserId}},\n  \"sourceText\": \"오늘은 몸도 마음도 지쳐서 가족에게 따뜻한 말을 듣고 싶어요.\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/family-insights",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "family-insights"
              ]
            },
            "description": "Requires a CONNECTED family relationship and GEMINI_API_KEY."
          },
          "response": []
        },
