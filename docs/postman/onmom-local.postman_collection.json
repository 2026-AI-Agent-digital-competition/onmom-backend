  "item": [
    {
      "name": "00 Auth",
      "item": [
        {
          "name": "Dev Auth Status",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('dev auth is enabled', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.expect(json.data.enabled).to.eql(true);",
                  "  pm.expect(json.data.jwtSecretConfigured).to.eql(true);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/v1/dev/auth/status",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dev",
                "auth",
                "status"
              ]
            },
            "description": "Requires server option: --onmom.dev-token.enabled=true"
          },
          "response": []
        },
        {
          "name": "Create Mother Dev Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('mother token issued', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('motherToken', json.data.accessToken);",
                  "  pm.environment.set('motherUserId', String(json.data.userId));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{motherUserId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dev/auth/access-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dev",
                "auth",
                "access-token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Create Family Dev Token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('family token issued', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  pm.environment.set('familyToken', json.data.accessToken);",
                  "  pm.environment.set('familyUserId', String(json.data.userId));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{familyUserId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/dev/auth/access-token",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "dev",
                "auth",
                "access-token"
              ]
            }
          },
          "response": []
        },
        {
          "name": "Kakao Login",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('kakao login succeeds', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.expect(json.data.accessToken).to.be.a('string').and.not.empty;",
                  "  if (json.data.role === 'MOTHER') {",
                  "    pm.environment.set('motherToken', json.data.accessToken);",
                  "    pm.environment.set('motherUserId', String(json.data.userId));",
                  "  }",
                  "  if (json.data.role === 'FAMILY') {",
                  "    pm.environment.set('familyToken', json.data.accessToken);",
                  "    pm.environment.set('familyUserId', String(json.data.userId));",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"authorizationCode\": \"{{kakaoAuthorizationCode}}\",\n  \"role\": \"{{loginRole}}\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/auth/kakao-login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "auth",
                "kakao-login"
              ]
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "01 Pregnancy",
      "item": [
        {
          "name": "Create Pregnancy",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('pregnancy created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.environment.set('pregnancyId', String(json.data.id));",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{motherToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"motherDisplayName\": \"온맘\",\n  \"babyNickname\": \"튼튼이\",\n  \"pregnancyWeekStart\": 12,\n  \"pregnancyWeekEnd\": 13,\n  \"dueDate\": \"2027-01-01\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/pregnancies",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "pregnancies"
              ]
            },
            "description": "A mother can have only one ACTIVE pregnancy. If this returns ALREADY_EXISTS, reuse the existing pregnancy id from DataGrip or reset local data."
          },
          "response": []
        }
      ]
    },
    {
