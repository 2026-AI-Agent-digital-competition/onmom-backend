          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('family messages listed', function () {",
                  "  pm.response.to.have.status(200);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
