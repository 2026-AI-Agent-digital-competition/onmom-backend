    {
      "name": "04 Chat",
      "item": [
        {
          "name": "Create Chat Message",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('chat message created', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
