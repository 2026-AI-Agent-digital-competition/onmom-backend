    {
      "name": "03 Emotion Records",
      "item": [
        {
          "name": "Create Or Update Emotion Record",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('emotion record saved', function () {",
                  "  pm.response.to.have.status(201);",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.result).to.eql('SUCCESS');",
                  "  pm.environment.set('emotionRecordId', String(json.data.id));",
                  "  if (json.data.aiReportId) {",
                  "    pm.environment.set('emotionAiReportId', String(json.data.aiReportId));",
                  "  }",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "auth": {
              "type": "bearer",
              "bearer": [
                {
                  "key": "token",
                  "value": "{{motherToken}}",
                  "type": "string"
                }
              ]
            },
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"pregnancyId\": {{pregnancyId}},\n  \"recordDate\": \"{{recordDate}}\",\n  \"moodScore\": 3,\n  \"moodLabel\": \"불안\",\n  \"noteText\": \"오늘은 몸이 무겁고 마음이 조금 불안했어요.\",\n  \"source\": \"MANUAL\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/v1/emotion-records",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "v1",
                "emotion-records"
              ]
            },
            "description": "This request calls Gemini through the backend. GEMINI_API_KEY must be configured."
          },
          "response": []
        },
